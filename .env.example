# ==============================================================================
# SuezCanal.xyz - Environment Configuration
# ==============================================================================

# [EN] Authentication flag. Set to false for beta/local testing without Keycloak.
# [IT] Flag di autenticazione. Impostare su false per test beta/locali senza Keycloak.
SUEZCANAL_AUTH=false
SUEZCANAL_SIGNING_KEY=
DATABASE_URL=sqlite:///./core/data/suezcanal_pilot.db
REDIS_URL=redis://localhost:6379/0
VITE_API_BASE=

# [EN] Leave empty for internal pilot. Set one or more HTTPS endpoints only when you have real witness receivers.
# [IT] Lasciare vuoto per il pilot interno. Impostare endpoint HTTPS reali solo se esistono ricevitori witness.
WITNESS_ENDPOINTS=[]

# [EN] Enable SDR scanner for threat awareness (requires RTL-SDR hardware).
# [IT] Abilita lo scanner SDR per il rilevamento delle minacce (richiede hardware RTL-SDR).
SDR_ENABLED=false

# [EN] Copernicus Marine Service credentials (optional, for live ocean data).
# [IT] Credenziali Copernicus Marine Service (opzionali, per dati oceanici in tempo reale).
CMEMS_USERNAME=
CMEMS_PASSWORD=

# [EN] ECMWF CDS API Key for ERA5 atmospheric reanalysis (fallback).
# [IT] Chiave API ECMWF CDS per rianalisi atmosferica ERA5 (fallback).
# Get it here: https://cds.climate.copernicus.eu/api-how-to
CDSAPI_KEY=

# [EN] Path to the Python interpreter where OpenDrift is installed.
# [IT] Percorso dell'interprete Python dove e installato OpenDrift.
OPENDRIFT_PYTHON=C:\Users\repub\AppData\Local\Programs\Python\Python312\python.exe

# [EN] Constant forcing fallback used by the current OpenDrift integration.
# [IT] Forzanti costanti usate come fallback dall'integrazione OpenDrift attuale.
OPENDRIFT_WIND_X=4.0
OPENDRIFT_WIND_Y=1.0
OPENDRIFT_CURRENT_X=0.2
OPENDRIFT_CURRENT_Y=0.05
OPENDRIFT_PARTICLES=128
OPENDRIFT_TIMESTEP_SECONDS=900
OPENDRIFT_OUTPUT_SECONDS=3600

# ==============================================================================
# Passive Physical Sensors Configuration
# ==============================================================================

INFRASOUND_ENABLED=true
INFRASOUND_DEVICE=rboom          # rboom | diy_adc | none
INFRASOUND_STA_WINDOW=1.0         # seconds
INFRASOUND_LTA_WINDOW=30.0        # seconds
INFRASOUND_TRIGGER_RATIO=3.5      # STA/LTA threshold

SEISMIC_ENABLED=true
SEISMIC_DEVICE=adxl355            # adxl355 | none

HYDRO_ENABLED=false               # optional, over-the-side

CORRELATION_CONFIDENCE_ALERT=0.55  # threshold for PhysicalThreatEvent
CORRELATION_CONFIDENCE_URGENT=0.80 # threshold for URGENT push

RSNET_ENABLED=false               # Raspberry Shake citizen network
RSNET_STATION_CODE=               # assigned by raspberryshake.org
CTBTO_VDEC_ENABLED=false          # CTBTO open data (researcher account)

# ==============================================================================
# Ionospheric TID Sensor Configuration
# ==============================================================================
TID_ENABLED=false
TID_REGION_LAT=35.5
TID_REGION_LON=18.0
TID_REGION_RADIUS_KM=2000
TID_POLL_INTERVAL_S=60
TID_MIN_STATIONS=3
TID_IGS_MIRROR=https://cddis.nasa.gov/archive/gnss/data/hourly
TID_CORS_REGIONS=EUREF,MED

# ==============================================================================
# Ingestion Channel Configuration
# ==============================================================================

# Twilio credentials (WhatsApp + SMS inbound webhooks)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_SMS_NUMBER=+14155238886

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Twitter / X bearer token (for passive monitoring stream)
TWITTER_BEARER_TOKEN=

# ==============================================================================
# Probability Engine Configuration
# ==============================================================================

# Default Mediterranean environmental conditions (used when real data unavailable)
DEFAULT_WATER_TEMP_C=18
DEFAULT_AIR_TEMP_C=20
DEFAULT_WIND_MS=5
DEFAULT_WAVE_M=1

# How often to poll for updated environmental conditions (seconds)
ENV_POLL_INTERVAL_S=300

# ==============================================================================
# Development / Testing
# ==============================================================================

# Set to true to enable mock mode (no real APIs required)
MOCK=false

# Set to true for a public demo backend. This keeps the API lightweight and
# allows SAR cases to run with the Gaussian fallback when OpenDrift is unavailable.
DEMO_PUBLIC_MODE=false
