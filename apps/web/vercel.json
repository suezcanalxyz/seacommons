{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE": "https://seacommons-api-demo.onrender.com",
    "VITE_PUBLIC_BASE": "/",
    "VITE_MAPTILER_KEY": "@maptiler_key"
  }
}
